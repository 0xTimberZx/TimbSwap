					"notice": "PrizeEscrow — receives ETH pot top-ups."
				},
				"receiveFees()": {
					"notice": "Receive protocol fees from Router or TimbPrize."
				},
				"setBuybackBurnRatio(uint256)": {
					"notice": "Set buyback burn ratio (0–100).         0 = all to staking, 100 = all burned."
				},
