				"constructor": {
					"params": {
						"_rewardRatePerSecond": "Initial TIMBS emission rate per second.",
						"_timbsToken": "TIMBS ERC-20 address (reward token)."
					}
				},
				"notifyRewardAmount(uint256,uint256)": {
					"details": "Called by owner or TimbTreasury. Rolls over remaining rewards      if current period is still active.",
					"params": {
						"amount": "TIMBS to add.",
						"duration": "Seconds over which to distribute."
					}
				},
				"owner()": {
					"details": "Returns the address of the current owner."
				},
				"recoverERC20(address,uint256)": {
					"details": "Cannot recover staked LP tokens (protected by totalStaked)."
				},
				"renounceOwnership()": {
					"details": "Leaves the contract without owner. It will not be possible to call `onlyOwner` functions. Can only be called by the current owner. NOTE: Renouncing ownership will leave the contract without an owner, thereby disabling any functionality that is only available to the owner."
				},
				"setLpToken(address)": {
					"details": "Can only be set before first stake (lpTokenLocked = false).      After first stake, LP token is permanent — no rug vector."
				},
				"stake(uint256)": {
					"details": "Caller must approve this contract for lpToken before calling.      First stake locks the lpToken address permanently.",
					"params": {
						"amount": "LP token amount to stake."
					}
				},
				"transferOwnership(address)": {
					"details": "Transfers ownership of the contract to a new account (`newOwner`). Can only be called by the current owner."
				},
				"unstake(uint256)": {
					"details": "Collateral ownership enforced — msg.sender only.      Pending rewards NOT auto-claimed. Use exit() for combined op.",
					"params": {
						"amount": "LP token amount to unstake."
					}
				}
			},
