				"setRewardRate(uint256)": {
					"notice": "Update reward rate directly (owner only)."
				},
				"setTreasury(address)": {
					"notice": "Set TimbTreasury and authorise as reward notifier."
				},
				"stake(uint256)": {
					"notice": "Stake TIMBS/ETH LP tokens to earn TIMBS emissions."
