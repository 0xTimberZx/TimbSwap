			"methods": {
				"constructor": {
					"params": {
						"_feeTo": "Address that receives protocol fees (TimbTreasury)."
					}
				},
				"createPair(address,address)": {
					"details": "Permissionless — anyone can create a pair.      Pair address is fully determined (CREATE2) before any external      calls, preventing bonding-curve / reentrancy manipulation.      Tokens are sorted so token0 < token1 (canonical ordering).",
					"params": {
						"tokenA": "First token address.",
						"tokenB": "Second token address."
					},
					"returns": {
						"pair": "The address of the newly created pair contract."
					}
				},
				"getFeeConfig()": {
					"details": "Useful for Router to calculate fee distribution without      hardcoding values."
				},
				"owner()": {
					"details": "Returns the address of the current owner."
				},
				"renounceOwnership()": {
					"details": "Leaves the contract without owner. It will not be possible to call `onlyOwner` functions. Can only be called by the current owner. NOTE: Renouncing ownership will leave the contract without an owner, thereby disabling any functionality that is only available to the owner."
				},
				"setEmissionsWhitelist(address,bool)": {
					"details": "Only whitelisted pairs receive TIMBS staking/farm emissions.      At launch: TIMBS/ETH only. Owner-extendable."
				},
				"setPartnerPool(address,address,bool)": {
					"details": "When active, the pair routes LP fees to `destination`      instead of distributing pro-rata to LPs.      Use case: route fees to BlockpotDAO PrizeVault v3.      Not active at launch — opt-in per pool.",
					"params": {
						"active": "True to enable, false to disable.",
						"destination": "Where LP fees are sent (e.g. PrizeVault).",
						"pair": "The pair contract address."
					}
				},
				"setTimbsToken(address)": {
					"details": "Used to identify the TIMBS/ETH pair for emissions routing."
				},
				"transferOwnership(address)": {
					"details": "Transfers ownership of the contract to a new account (`newOwner`). Can only be called by the current owner."
				}
			},
			"title": "TimbSwapFactory",
			"version": 1
		},
		"userdoc": {
			"kind": "user",
			"methods": {
				"LP_FEE_BPS()": {
					"notice": "LP share of total fee in basis points (0.25% = 25 bps)."
				},
				"PROTOCOL_FEE_BPS()": {
					"notice": "Protocol share of total fee in basis points (0.05% = 5 bps)."
				},
				"TOTAL_FEE_BPS()": {
					"notice": "Total swap fee in basis points (0.3% = 30 bps)."
				},
				"allPairs(uint256)": {
					"notice": "All created pairs in order of creation."
				},
				"allPairsLength()": {
					"notice": "Total number of pairs created."
				},
				"createPair(address,address)": {
					"notice": "Create a new AMM pair for tokenA and tokenB."
				},
				"emissionsWhitelist(address)": {
					"notice": "Pairs eligible for TIMBS emissions rewards.         Only TIMBS/ETH LP at launch — owner-extendable."
				},
				"feeTo()": {
					"notice": "Address that receives the protocol fee (TimbTreasury)."
				},
				"getFeeConfig()": {
					"notice": "Returns protocol fee split in basis points."
				},
				"getPair(address,address)": {
					"notice": "token0 => token1 => pair address.         token0 < token1 always (sorted on creation)."
				},
				"getPairAddress(address,address)": {
					"notice": "Returns the pair address for two tokens (either order).         Returns address(0) if the pair doesn't exist."
				},
				"getPartnerConfig(address)": {
					"notice": "Returns partner pool config for a pair."
				},
				"isPairEmissionsEligible(address)": {
					"notice": "Returns whether a pair is eligible for TIMBS emissions."
				},
				"isPartnerPool(address)": {
					"notice": "Partner pool flag — pair routes LP fees to an external         destination instead of distributing to LPs directly.         Opt-in, owner-set per pair. Not active at launch."
				},
				"partnerDestination(address)": {
					"notice": "Partner destination per pair — where LP fees are routed         when isPartnerPool[pair] == true."
				},
				"pause()": {
					"notice": "Pause pair creation. Emergency use only."
				},
				"paused()": {
					"notice": "Pair creation paused (emergency)."
				},
				"router()": {
					"notice": "Registered TimbSwapRouter — only address allowed to         call privileged factory functions."
				},
				"setEmissionsWhitelist(address,bool)": {
					"notice": "Add or remove a pair from the TIMBS emissions whitelist."
				},
				"setFeeTo(address)": {
					"notice": "Update the protocol fee recipient (TimbTreasury)."
				},
				"setPartnerPool(address,address,bool)": {
					"notice": "Designate a pair as a partner pool."
				},
				"setRouter(address)": {
					"notice": "Register the TimbSwapRouter. Required before any swaps."
				},
				"setTimbsToken(address)": {
					"notice": "Set the TIMBS token address."
				},
				"timbsToken()": {
					"notice": "TIMBS token address — used to identify the emissions pair."
				},
				"unpause()": {
					"notice": "Unpause pair creation."
				}
			},
			"notice": "Creates and indexes TimbSwap AMM pairs. Architecture:   - Uniswap v2-style factory: one pair per token0/token1 combination.   - 0.3% flat fee per swap (0.25% LP, 0.05% protocol).   - Partner pool flag: any pair can be designated to route LP fees     to an external destination (e.g. BlockpotDAO PrizeVault v3).     This is opt-in, owner-configurable per pair, not active at launch.   - Permissionless pair creation — anyone can create a pair.   - Emissions whitelist — only owner can add pairs to TIMBS rewards list. Security (defiSKILL):   - ReentrancyGuard on createPair() — pair address determined before     any external calls (prevents bonding-curve / phi H-06 pattern).   - Pair stored atomically: allPairs + getPair updated in same tx.   - No TOCTOU on pair creation (existence check before CREATE2).   - Emergency pause on pair creation.   - Router authorization stored here — Router must be registered     before it can call privileged factory functions. Deployment order:   1. Deploy TimbSwapFactory(feeTo, protocolFeeBps)   2. Deploy TimbSwapRouter(factory)   3. Call factory.setRouter(router)   4. Deploy TIMBSToken, then call setTimbsToken(address)   5. createPair(TIMBS, WETH) — seeds the emissions pair   6. addToEmissionsWhitelist(pair) for TIMBS/ETH pair only",
			"version": 1
		}
	},
