			"kind": "dev",
			"methods": {
				"activateRoundEntries(uint256,address[])": {
					"details": "Called by TimbPrize when a new round begins.      Sets all Pending entries for this round to Active.      Only TimbPrize can call.",
					"params": {
						"players": "Array of player addresses with entries in this round.",
						"round": "The round number being activated."
					}
				},
				"claimRefund(uint256)": {
					"details": "Available after entry's lastEligibleRound has passed AND      claim window (2 rounds) has not closed.      Caller must be the original entry owner.",
					"params": {
						"round": "The round the entry was playing in."
					}
				},
				"constructor": {
					"params": {
						"_protocolSink": "Address that receives additional-round TIMBS sinks.",
						"_timbPrize": "TimbPrize contract (can be set later via setTimbPrize).",
						"_timbsToken": "TIMBS ERC-20 address."
					}
				},
				"expireEntry(address,uint256)": {
					"details": "Called by TimbPrize at round close for entries past their window."
				},
				"getIdenticalCount(bytes6)": {
					"details": "Frontend calls this after entry submission to show collision count."
				},
				"getStringEntrants(uint256,bytes6)": {
					"details": "Used by TimbPrize at settlement to find winner candidates.      Returns raw list — settlement applies dual-layer filter."
				},
				"markInactive(address,uint256)": {
					"details": "Called by TimbPrize when unclaimed window expires."
				},
				"owner()": {
					"details": "Returns the address of the current owner."
				},
				"renounceOwnership()": {
					"details": "Leaves the contract without owner. It will not be possible to call `onlyOwner` functions. Can only be called by the current owner. NOTE: Renouncing ownership will leave the contract without an owner, thereby disabling any functionality that is only available to the owner."
				},
				"replaceEntry(bytes6,uint256)": {
					"details": "All-in-one atomic transaction:   1. Pre-flight: verify contract can pull new fees.   2. Old initial deposit transfers to new string entry.   3. Old additional-round TIMBS already in sink — no action needed.   4. New string set on-chain.   5. New additional-round TIMBS pulled to sink if extraRounds > 0.      Pre-flight check happens BEFORE any state changes (defiSKILL).",
					"params": {
						"extraRounds": "New total extra rounds beyond N+1.",
						"newString6": "New 6-char string."
					}
				},
				"setCurrentRound(uint256)": {
					"details": "Called by TimbPrize at each round start."
				},
				"setEntryCosts(uint256,uint256)": {
					"details": "Called by owner when governance updates entryCostTIMBS or      when TIMBS/ETH price moves and ETH cost needs updating."
				},
				"submitEntry(bytes6,bool,uint256)": {
					"details": "Entries set in currentRound play in currentRound + 1.      ETH entries: send msg.value == entryCostETH.      TIMBS entries: approve this contract for entryCostTIMBS first.      Additional rounds: must also approve        extraRounds × entryCostTIMBS additional TIMBS.",
					"params": {
						"extraRounds": "Additional rounds to keep string active beyond N+1.                      Each costs entryCostTIMBS TIMBS (non-refundable).",
						"string6": "6-char entry string (A-Z, 0-9, no repeats, uppercase).",
						"useETH": "True = pay initial cost in ETH, false = TIMBS."
					}
				},
				"transferOwnership(address)": {
					"details": "Transfers ownership of the contract to a new account (`newOwner`). Can only be called by the current owner."
				},
				"validateString(bytes6)": {
					"returns": {
						"reason": "Empty string if valid, human-readable reason if not.",
						"valid": "True if the string passes all validation rules."
					}
				},
				"verifyEntryExisted(address,uint256)": {
					"params": {
						"player": "Wallet address.",
						"round": "Round number to check."
					},
					"returns": {
						"exists": "True if entry was submitted for this round.",
						"string6": "The entry string (bytes6(0) if not found)."
					}
				},
				"verifyEntryValid(address,uint256)": {
					"params": {
						"player": "Wallet address.",
						"round": "Round number."
					},
					"returns": {
						"string6": "The current entry string.",
						"valid": " True if entry is Active and round <= lastEligibleRound."
					}
				}
			},
