			"kind": "dev",
			"methods": {
				"claimWinnings(uint256)": {
					"details": "Dual-layer verification: entry existed at round start AND      string matched AND claim window still open.      ETH paid from PrizeEscrow.",
					"params": {
						"round": "Round number to claim from."
					}
				},
				"constructor": {
					"params": {
						"_gameRegistry": "GameRegistry contract address.",
						"_prizeEscrow": "PrizeEscrow contract address.",
						"_router": "TimbSwapRouter address."
					}
				},
				"fundPot()": {
					"details": "Forwards ETH to PrizeEscrow and adds to accumulated rewards."
				},
				"getCurrentWindow()": {
					"details": "alphabet[(positionCounter + i) % 36] for i = 0..5.      Frontend also computes this — contract provides it for verification."
				},
				"getWindowAt(uint256)": {
					"details": "Used for historical replay and frontend simulation."
				},
				"nudgeScroll()": {
					"details": "Called by TimbSwapRouter after a confirmed eligible swap.      Blocked during the 0:15 settlement window.      Router checks EligibleTokenRegistry before calling."
				},
				"owner()": {
					"details": "Returns the address of the current owner."
				},
				"renounceOwnership()": {
					"details": "Leaves the contract without owner. It will not be possible to call `onlyOwner` functions. Can only be called by the current owner. NOTE: Renouncing ownership will leave the contract without an owner, thereby disabling any functionality that is only available to the owner."
				},
				"settleSegment()": {
					"details": "Settler calls this after INTERACTION_WINDOW has elapsed.      On segments 1–5: advances to next segment.      On segment 6: freezes position, finds winners, settles round.      Reverts if called too early (on-chain timing enforcement)."
				},
				"startGame()": {
					"details": "Owner-only. Called once after all contracts are deployed and funded."
				},
				"transferOwnership(address)": {
					"details": "Transfers ownership of the contract to a new account (`newOwner`). Can only be called by the current owner."
				}
			},
			"title": "TimbPrize",
			"version": 1
		},
