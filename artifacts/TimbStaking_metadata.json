			"kind": "dev",
			"methods": {
				"claimRewards()": {
					"details": "Reward balance checked before transfer —      reverts if contract doesn't have enough TIMBS to pay."
				},
				"constructor": {
					"params": {
						"_rewardRatePerSecond": "Initial reward rate (TIMBS wei per second).",
						"_timbsToken": "TIMBS ERC-20 token address."
					}
				},
				"emergencyWithdraw()": {
					"details": "Safety valve only. Rewards are NOT paid on emergency withdraw."
				},
				"notifyRewardAmount(uint256,uint256)": {
					"details": "Called by owner or TimbTreasury (after buyback) to deposit      TIMBS and activate a new reward period.      If a period is still active, remaining rewards are rolled      into the new period before recalculating the rate.",
					"params": {
						"amount": "TIMBS amount to add to reward pool.",
						"duration": "Duration in seconds over which to distribute."
					}
				},
				"owner()": {
					"details": "Returns the address of the current owner."
				},
				"recoverERC20(address,uint256)": {
					"details": "Cannot recover staked TIMBS (protected by totalStaked check)."
				},
				"renounceOwnership()": {
					"details": "Leaves the contract without owner. It will not be possible to call `onlyOwner` functions. Can only be called by the current owner. NOTE: Renouncing ownership will leave the contract without an owner, thereby disabling any functionality that is only available to the owner."
				},
				"setRewardRate(uint256)": {
					"details": "Snapshots accumulator before changing rate.      Use notifyRewardAmount() for funding + rate update in one call."
				},
				"stake(uint256)": {
					"details": "No unique stake IDs — adds to accumulated balance.      Caller must approve this contract before calling.",
					"params": {
						"amount": "TIMBS amount to stake (18 decimals)."
					}
				},
				"transferOwnership(address)": {
					"details": "Transfers ownership of the contract to a new account (`newOwner`). Can only be called by the current owner."
				},
				"unstake(uint256)": {
					"details": "Collateral ownership verified: msg.sender can only unstake      their own balance. No delegate unstake.      Pending rewards are NOT auto-claimed — call claimRewards() separately      or use exit() for a combined unstake + claim.",
					"params": {
						"amount": "TIMBS amount to unstake."
					}
				}
			},
			"title": "TimbStaking",
			"version": 1
		},
		"userdoc": {
			"kind": "user",
			"methods": {
				"claimRewards()": {
					"notice": "Claim all pending TIMBS rewards."
				},
				"earned(address)": {
					"notice": "Returns total TIMBS earned (pending + unsnapshotted) for `account`."
				},
				"emergencyWithdraw()": {
					"notice": "Emergency withdraw — allows user to recover staked TIMBS         even when paused. Forfeits pending rewards."
				},
				"estimatedAPR()": {
					"notice": "Estimated annual yield for `account` at current rate.         Informational — actual yield depends on total staked changing."
				},
				"exit()": {
					"notice": "Unstake all TIMBS and claim all pending rewards in one tx."
				},
				"lastTimeRewardApplicable()": {
					"notice": "Returns the applicable timestamp for reward accrual.         Caps at periodFinish so rewards stop after the period ends."
				},
				"lastUpdateTime()": {
					"notice": "Last timestamp rewardPerTokenStored was updated."
				},
				"notifyRewardAmount(uint256,uint256)": {
					"notice": "Fund the reward pool and set the distribution period."
				},
				"pause()": {
					"notice": "Emergency pause — halts stake/unstake/claim."
				},
				"paused()": {
					"notice": "Emergency pause flag."
				},
				"pendingRewards(address)": {
					"notice": "Pending (earned but unclaimed) rewards per address."
				},
				"periodFinish()": {
					"notice": "Timestamp when current reward period ends."
				},
				"recoverERC20(address,uint256)": {
					"notice": "Owner can recover ERC20 tokens accidentally sent to this contract."
				},
				"rewardNotifiers(address)": {
					"notice": "Addresses authorised to call notifyRewardAmount()         (owner + treasury)."
				},
				"rewardPerToken()": {
					"notice": "Returns cumulative TIMBS earned per staked TIMBS since deploy."
				},
				"rewardPerTokenStored()": {
					"notice": "Cumulative TIMBS earned per staked TIMBS (18-decimal fixed point)."
				},
				"rewardRatePerSecond()": {
					"notice": "TIMBS rewards distributed per second across all stakers.         Owner-set. Changing mid-period snapshots the current accumulator."
				},
				"setRewardNotifier(address,bool)": {
					"notice": "Add or remove a reward notifier address."
				},
				"setRewardRate(uint256)": {
					"notice": "Update the reward rate directly (owner only)."
				},
				"setTreasury(address)": {
					"notice": "Set TimbTreasury address and authorise it as a reward notifier."
				},
				"stake(uint256)": {
					"notice": "Stake TIMBS to start earning rewards."
				},
				"stakedBalance(address)": {
					"notice": "Staked balance per address."
				},
				"timbsToken()": {
					"notice": "TIMBS token — staked and earned."
				},
				"totalStaked()": {
					"notice": "Total TIMBS currently staked across all users."
				},
				"treasury()": {
					"notice": "TimbTreasury — authorised to call notifyRewardAmount()."
				},
				"unstake(uint256)": {
					"notice": "Reduce or fully withdraw staked TIMBS."
				},
				"userRewardPerTokenPaid(address)": {
					"notice": "Snapshot of rewardPerTokenStored when user last interacted."
				}
			},
			"notice": "Single-asset TIMBS staking pool. Model:   - Stake TIMBS, earn TIMBS distributions.   - Reward source: treasury-seeded allocation + buyback distributions     sent by TimbTreasury after each buyback execution.   - Fixed APR set by owner (changeable anytime).   - Rewards accrue per-second proportional to staker's share.   - No unique stake IDs — single accumulated balance per address.   - Free add/reduce/withdraw anytime — no lock, no penalty. Reward calculation (MasterChef-style rewardPerToken accumulator):   rewardPerTokenStored tracks cumulative TIMBS earned per staked TIMBS.   On every interaction, pending rewards are snapshotted for the user.   This avoids looping over stakers and scales to any number of users. Security (defiSKILL):   - ReentrancyGuard on stake(), unstake(), claimRewards().   - Collateral ownership: all functions verify msg.sender owns the stake     (no delegate staking without explicit approval).   - Flash loan protection: reward accrual uses time-weighted accumulator,     not spot balance — flash staking earns nothing meaningful.   - SafeERC20 on all token transfers.   - Emergency pause on stake/unstake/claim.   - notifyRewardAmount() restricted to owner + treasury (authorised callers). Deployment:   1. Deploy TimbStaking(timbsToken, rewardRatePerSecond)   2. TIMBSToken.setStakingPool(address(this))   3. Fund with initial TIMBS reward allocation from treasury   4. TimbTreasury.setStakingPool(address(this)) for buyback distributions",
			"version": 1
		}
	},
