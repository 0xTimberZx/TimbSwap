# ─── TimbSwap Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to git. It is in .gitignore.
# NEVER share your DEPLOYER_PRIVATE_KEY with anyone.

# ─── Deployer ─────────────────────────────────────────────────────────────────

# Private key of the deployer wallet (no 0x prefix needed by Foundry)
DEPLOYER_PRIVATE_KEY=

# ─── Network ──────────────────────────────────────────────────────────────────

# Arbitrum Sepolia RPC URL
# Free options: Alchemy, Infura, QuickNode, or public https://sepolia-rollup.arbitrum.io/rpc
ARB_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc

# Arbiscan API key (only needed for Etherscan verification — prefer Sourcify)
ARBISCAN_API_KEY=

# ─── Protocol Wallets ─────────────────────────────────────────────────────────

# Treasury / team wallet — receives initial TIMBS mint and protocol fees
TREASURY_ADDRESS=0x486Fa4D8351EF81136E83340eA1e3aa2272c9955

# Protocol sink — receives additional-round TIMBS fees (out of circulation)
# Can be the treasury wallet or a separate burn/sink address
PROTOCOL_SINK_ADDRESS=

# ─── Token Addresses (Arbitrum Sepolia) ───────────────────────────────────────

# WETH on Arbitrum Sepolia
WETH_ADDRESS=0x980B62Da83eFf3D4576C647993b0c1D7faf17c73

# Existing DAPP token (0xtimberzx ecosystem)
DAPP_TOKEN_ADDRESS=0x3d0cB8929c22F93A9dd33921E6f43C1621FCfC04

# LINK token on Arbitrum Sepolia (for lock vault whitelist)
LINK_TOKEN_ADDRESS=0xb1D4538B4571d411F07960EF2838Ce337FE1E80E

# ─── TIMBS Token Config ───────────────────────────────────────────────────────

# Total initial TIMBS supply (18 decimals)
# 100,000,000 TIMBS = 100000000000000000000000000
INITIAL_SUPPLY=100000000000000000000000000

# Initial prize game entry cost in TIMBS (18 decimals)
# 100 TIMBS = 100000000000000000000
ENTRY_COST_TIMBS=100000000000000000000

# Initial prize game entry cost in ETH wei
# 0.001 ETH = 1000000000000000
ENTRY_COST_ETH=1000000000000000

# ─── Staking / Farm ───────────────────────────────────────────────────────────

# TIMBS staking reward rate per second (18 decimals)
# Example: 1 TIMBS/sec = 86,400 TIMBS/day
# Adjust based on intended APR and total staked expectation
REWARD_RATE_PER_SEC=1000000000000000000

# TIMBS farm (LP) reward rate per second (18 decimals)
# LP farm typically higher rate than single-asset staking
FARM_REWARD_RATE=2000000000000000000

# ─── Governance ───────────────────────────────────────────────────────────────

# Minimum TIMBS balance to submit a governance proposal (18 decimals)
# 1,000 TIMBS = 1000000000000000000000
PROPOSAL_THRESHOLD=1000000000000000000000

# Quorum requirement in basis points (10000 = 100%)
# 1000 = 10% of deposited voting power must participate
QUORUM_BPS=1000

# Voting period in seconds
# 604800 = 7 days
VOTING_PERIOD=604800

# Voting delay in seconds (time between proposal creation and voting start)
# 86400 = 1 day
VOTING_DELAY=86400
